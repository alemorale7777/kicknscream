# Database — Neon Postgres
# Pooled connection (used by app at runtime)
DATABASE_URL="postgresql://USER:PASS@HOST/db?sslmode=require&pgbouncer=true&connection_limit=1"
# Direct connection (used by Prisma migrations)
DIRECT_URL="postgresql://USER:PASS@HOST/db?sslmode=require"

# NextAuth (Auth.js v5)
# Generate with: openssl rand -base64 32  OR  pnpm dlx auth secret
AUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Email — Resend (magic links + transactional)
AUTH_RESEND_KEY=""
EMAIL_FROM="KickNScream <onboarding@resend.dev>"

# Google OAuth
# Redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Vercel Blob (auto-injected after `vercel link` + Blob store created)
BLOB_READ_WRITE_TOKEN=""

# Stripe (Sprint 3+ — leave blank for Sprint 1)
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# HMAC key for audit-log email hashing. Generate with:
#   openssl rand -hex 32
# Once set in production, do not rotate — rotating invalidates audit search
# continuity for prior rows.
AUDIT_EMAIL_HMAC_SECRET=

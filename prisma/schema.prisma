// KickNScream multi-tenant schema
// COACH | INSTITUTION | CLUB share 80% of this schema; the 20% delta is
// feature-flagged at the application layer, not the database.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =====================================================================
// AUTH (NextAuth/Auth.js v5 — required tables)
// =====================================================================

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  name          String?
  phone         String?
  emailVerified DateTime?
  image         String?
  memberships   Membership[]
  sessions      Session[]
  accounts      Account[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// =====================================================================
// TENANCY
// =====================================================================

enum TenantType {
  COACH
  INSTITUTION
  CLUB
}

enum Role {
  OWNER // founder/owner of the tenant
  ADMIN // full management access
  COACH // can lead sessions, take attendance, write notes
  PARENT // has player(s) registered
  PLAYER // the kid (linked to parent)
}

model Tenant {
  id                      String                @id @default(cuid())
  slug                    String                @unique
  name                    String
  type                    TenantType
  logoUrl                 String?
  primaryColor            String?
  stripeAccountId         String?
  // KYC mirror columns kept fresh by the account.updated webhook
  stripeChargesEnabled    Boolean               @default(false)
  stripePayoutsEnabled    Boolean               @default(false)
  stripeDetailsSubmitted  Boolean               @default(false)
  stripeRequirementsDueAt DateTime?
  subscription            Subscription?
  memberships             Membership[]
  locations               Location[]
  programs                Program[]
  players                 Player[]
  events                  Event[]
  invoices                Invoice[]
  waivers                 Waiver[]
  invitations             Invitation[]
  tryouts                 TryoutSignup[]
  threads                 Thread[]
  messages                Message[]
  files                   File[]
  auditEntries            AuditLog[]
  permissionsOverrides    PermissionsOverride[]
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
}

model Membership {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  role      Role
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, tenantId])
  @@index([tenantId])
}

model Invitation {
  id         String    @id @default(cuid())
  tenantId   String
  email      String
  role       Role
  token      String    @unique
  expiresAt  DateTime
  acceptedAt DateTime?
  invitedBy  String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())

  @@index([tenantId])
  @@index([email])
}

model Location {
  id       String  @id @default(cuid())
  tenantId String
  name     String
  address  String?
  events   Event[]
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// =====================================================================
// PROGRAMS, EVENTS, PLAYERS, ATTENDANCE
// =====================================================================

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ELITE
}

enum PriceModel {
  PER_SESSION
  PACKAGE
  MONTHLY
  SEASON
  FREE
}

enum ServiceType {
  SINGLE
  PACK
  MEMBERSHIP
  PROGRAM
}

model Program {
  id                String       @id @default(cuid())
  tenantId          String
  name              String
  description       String?
  ageMin            Int?
  ageMax            Int?
  skillLevel        SkillLevel?
  price             Int // in cents
  priceModel        PriceModel
  capacity          Int?
  archived          Boolean      @default(false)
  // Phase B service product additions
  type              ServiceType?
  packSize          Int?
  recurringInterval String?
  cohortStart       DateTime?
  cohortEnd         DateTime?
  bookingLinkToken  String?      @unique
  thumbnailUrl      String?
  events            Event[]
  enrollments       Enrollment[]
  tenant            Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

enum EventType {
  LESSON
  CLASS
  PRACTICE
  GAME
  TRYOUT
  CAMP
  CLINIC
}

model Event {
  id                String        @id @default(cuid())
  tenantId          String
  programId         String?
  locationId        String?
  type              EventType
  title             String
  startsAt          DateTime
  endsAt            DateTime
  capacity          Int?
  // Recurrence linkage — every event in the same series shares this id.
  // Lets us scope bulk edits to "this", "this+future", or "all" without
  // moving to a derived-RRULE model.
  recurringSeriesId String?
  attendances       Attendance[]
  notes             SessionNote[]
  tenant            Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  program           Program?      @relation(fields: [programId], references: [id])
  location          Location?     @relation(fields: [locationId], references: [id])

  @@index([tenantId, startsAt])
  @@index([programId])
  @@index([recurringSeriesId])
}

model Player {
  id               String            @id @default(cuid())
  tenantId         String
  firstName        String
  lastName         String
  dob              DateTime
  parentId         String?
  // Legacy single-position field (kept for compat); use positions[] for new code
  position         String?
  positions        String[]          @default([])
  skillTags        String[]          @default([])
  photoUrl         String?
  notesPrivate     String?
  jerseyNumber     Int?
  notes            String?
  enrollments      Enrollment[]
  attendances      Attendance[]
  developmentNotes DevelopmentNote[]
  waiverSignatures WaiverSignature[]
  parentLinks      ParentPlayer[]
  files            File[]
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// Many-to-many parent ↔ player. The Player.parentId field stays as the
// primary parent for compat with existing code; ParentPlayer represents
// additional guardians (co-parent, grandparent, etc.).
model ParentPlayer {
  id           String   @id @default(cuid())
  parentUserId String
  playerId     String
  relationship String   @default("parent")
  createdAt    DateTime @default(now())
  player       Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([parentUserId, playerId])
  @@index([parentUserId])
}

enum EnrollmentStatus {
  PENDING
  ACTIVE
  WAITLIST
  CANCELED
  COMPLETED
  // Added in Phase B
  CONFIRMED
  PAID
  ATTENDED
  NO_SHOW
  REFUNDED
}

model Enrollment {
  id                 String           @id @default(cuid())
  playerId           String
  programId          String
  status             EnrollmentStatus
  invoiceId          String?
  attendedAt         DateTime?
  cancellationReason String?
  recurringSeriesId  String?
  packBalance        Int?
  player             Player           @relation(fields: [playerId], references: [id], onDelete: Cascade)
  program            Program          @relation(fields: [programId], references: [id])
  invoice            Invoice?         @relation(fields: [invoiceId], references: [id])
  createdAt          DateTime         @default(now())

  @@index([programId])
  @@index([playerId])
  @@index([recurringSeriesId])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
  PENDING
}

model Attendance {
  id          String           @id @default(cuid())
  eventId     String
  playerId    String
  status      AttendanceStatus
  checkedInAt DateTime?
  checkedInBy String?
  event       Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  player      Player           @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([eventId, playerId])
}

model SessionNote {
  id              String   @id @default(cuid())
  eventId         String
  playerId        String?
  authorId        String
  content         String
  visibleToParent Boolean  @default(true)
  event           Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
}

model DevelopmentNote {
  id        String   @id @default(cuid())
  playerId  String
  authorId  String
  category  String?
  rating    Int?
  content   String
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

// =====================================================================
// PAYMENTS — handles Stripe, cash, check, Venmo, Zelle
// =====================================================================

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIAL
  PAID
  OVERDUE
  VOIDED
}

model Invoice {
  id                    String        @id @default(cuid())
  tenantId              String
  payerEmail            String
  amount                Int // cents
  currency              String        @default("usd")
  status                InvoiceStatus
  description           String?
  stripePaymentIntentId String?
  payments              Payment[]
  enrollments           Enrollment[]
  tenant                Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt             DateTime      @default(now())
  paidAt                DateTime?

  @@index([tenantId, status])
}

enum PaymentMethod {
  CARD
  CASH
  CHECK
  VENMO
  ZELLE
  PAYPAL
  ACH
  OTHER
}

model Payment {
  id         String        @id @default(cuid())
  invoiceId  String
  amount     Int
  method     PaymentMethod
  reference  String?
  recordedBy String?
  invoice    Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  createdAt  DateTime      @default(now())
}

// =====================================================================
// WAIVERS
// =====================================================================

model Waiver {
  id         String            @id @default(cuid())
  tenantId   String
  title      String
  body       String
  required   Boolean           @default(true)
  signatures WaiverSignature[]
  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model WaiverSignature {
  id          String   @id @default(cuid())
  waiverId    String
  playerId    String
  signerName  String
  signerEmail String
  signedAt    DateTime @default(now())
  ipAddress   String?
  waiver      Waiver   @relation(fields: [waiverId], references: [id], onDelete: Cascade)
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

// =====================================================================
// SUBSCRIPTIONS — KickNScream platform billing (not parents-pay-tenant)
// =====================================================================

enum SubPlan {
  COACH_FREE
  COACH_PRO
  COACH_ELITE
  INST_STARTER
  INST_GROWTH
  INST_SCALE
  CLUB_STANDARD
  CLUB_PRO
}

model Subscription {
  id               String    @id @default(cuid())
  tenantId         String    @unique
  plan             SubPlan
  stripeSubId      String?
  status           String
  currentPeriodEnd DateTime?
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// =====================================================================
// CLUB — tryouts/recruitment
// =====================================================================

enum TryoutStatus {
  PENDING
  INVITED
  ATTENDED
  OFFERED
  ACCEPTED
  DECLINED
}

model TryoutSignup {
  id          String       @id @default(cuid())
  tenantId    String
  playerName  String
  parentEmail String
  parentPhone String?
  ageGroup    String
  videoUrl    String?
  notes       String?
  status      TryoutStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
}

// =====================================================================
// PHASE B — MESSAGING, FILES, AUDIT, PERMISSIONS, IDEMPOTENCY, PREFS
// =====================================================================

enum MessageChannel {
  IN_APP
  EMAIL
  SMS
}

model Thread {
  id             String    @id @default(cuid())
  tenantId       String
  subject        String?
  participantIds String[]
  lastMessageAt  DateTime  @default(now())
  createdAt      DateTime  @default(now())
  messages       Message[]
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, lastMessageAt(sort: Desc)])
}

model Message {
  id           String         @id @default(cuid())
  tenantId     String
  threadId     String
  senderUserId String
  body         String
  channel      MessageChannel @default(IN_APP)
  deliveredAt  DateTime?
  readAt       DateTime?
  createdAt    DateTime       @default(now())
  thread       Thread         @relation(fields: [threadId], references: [id], onDelete: Cascade)
  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt(sort: Desc)])
  @@index([tenantId])
}

enum FileKind {
  WAIVER
  MEDICAL
  PHOTO
  DOC
}

model File {
  id          String    @id @default(cuid())
  tenantId    String
  ownerUserId String?
  playerId    String?
  kind        FileKind
  url         String
  filename    String?
  signedAt    DateTime?
  createdAt   DateTime  @default(now())
  player      Player?   @relation(fields: [playerId], references: [id], onDelete: SetNull)
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, kind])
  @@index([playerId])
}

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  actorUserId String?
  action      String
  targetType  String?
  targetId    String?
  diff        Json?
  createdAt   DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([targetType, targetId])
}

enum PermissionLevel {
  NONE
  VIEW
  EDIT
}

model PermissionsOverride {
  id        String          @id @default(cuid())
  tenantId  String
  role      Role
  feature   String
  level     PermissionLevel
  updatedAt DateTime        @updatedAt
  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, role, feature])
}

// Stripe webhook idempotency — Stripe retries aggressively; we log every
// event ID we've processed so retries become no-ops.
model StripeWebhookEvent {
  id          String   @id @default(cuid())
  stripeId    String   @unique
  type        String
  processedAt DateTime @default(now())
  payload     Json?

  @@index([type])
}

model UserPreferences {
  id             String   @id @default(cuid())
  userId         String   @unique
  theme          String? // 'dark' | 'light' | 'system'
  emailReminders Boolean  @default(true)
  emailPayments  Boolean  @default(true)
  emailMessages  Boolean  @default(true)
  pushReminders  Boolean  @default(true)
  pushPayments   Boolean  @default(true)
  pushMessages   Boolean  @default(true)
  smsOptIn       Boolean  @default(false)
  smsReminders   Boolean  @default(false)
  smsPayments    Boolean  @default(false)
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())
}
